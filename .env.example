# Environment: development, test, staging, or production.
# Local development should stay on development.
# Staging and production require a long ADMIN_API_KEY.
NODE_ENV=development

# Service ports
CALL_REQUESTS_SERVICE_PORT=3000
SCHEDULER_SERVICE_PORT=3001
COMMUNICATION_SERVICE_PORT=3002

# Data stores
MONGODB_URI=mongodb://localhost:27017/call-reservation
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_CALLS_EXCHANGE=calls.exchange

# Admin/API security
ADMIN_API_KEY=dev-admin-key

# RabbitMQ queues
RABBITMQ_CALL_REQUESTED_QUEUE=communication.call-requested
RABBITMQ_CALL_APPROVED_QUEUE=communication.call-approved
RABBITMQ_CALL_REJECTED_QUEUE=communication.call-rejected
RABBITMQ_CALL_CANCELED_QUEUE=communication.call-canceled
RABBITMQ_CALL_REMINDER_QUEUE=communication.call-reminder
RABBITMQ_DAILY_DIGEST_QUEUE=communication.daily-digest
RABBITMQ_EMAIL_DEAD_LETTER_QUEUE=communication.email-dead-letter
RABBITMQ_CALL_APPROVED_SCHEDULER_QUEUE=scheduler.call-approved
RABBITMQ_CALL_CANCELED_SCHEDULER_QUEUE=scheduler.call-canceled

# Public URLs
PUBLIC_BOOKING_BASE_URL=http://localhost:3000/api

# Email
ADMIN_EMAIL=amir@gmail.com
EMAIL_MAX_RETRY_ATTEMPTS=3
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# Calendar OAuth/token protection
CALENDAR_TOKEN_ENCRYPTION_SECRET=replace-with-a-long-random-string
GOOGLE_CALENDAR_CLIENT_ID=your-google-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar-connections/google/callback
GOOGLE_CALENDAR_STATE_SECRET=replace-with-a-long-random-string

# Public booking rate limits
PUBLIC_BOOKING_RATE_LIMIT_STORE=memory
REDIS_URL=redis://localhost:6379
PUBLIC_BOOKING_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_BOOKING_RATE_LIMIT_LOOKUP_MAX=120
PUBLIC_BOOKING_RATE_LIMIT_AVAILABILITY_MAX=120
PUBLIC_BOOKING_RATE_LIMIT_CREATE_MAX=10
PUBLIC_BOOKING_RATE_LIMIT_MANAGE_MAX=30

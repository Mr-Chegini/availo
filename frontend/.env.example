# Browser-facing API base URL.
# Local: http://localhost:3000/api
# Staging/production: use the public HTTPS API URL for that environment.
VITE_API_BASE_URL=http://localhost:3000/api

# Local/MVP admin API key for the React Admin View.
# Vite exposes VITE_* values to browser code; do not use this as real admin auth
# for production customer traffic.
VITE_ADMIN_API_KEY=dev-admin-key
